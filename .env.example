# n8n server environment
NODE_FUNCTION_ALLOW_BUILTIN=crypto
NODE_FUNCTION_ALLOW_EXTERNAL=node-fetch
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_VIDEO_JWT_SECRET="long-random-secret-shared-with-your-website-backend"
N8N_VIDEO_USER_HASH_SECRET="different-long-random-secret"
OPENAI_API_KEY="replace-with-openai-api-key"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-secret-key"
OPENAI_VIDEO_MODEL=sora-2
N8N_VIDEO_DAILY_LIMIT=5
VIDEO_SIGNED_URL_TTL_SECONDS=3600
N8N_VIDEO_RETENTION_DAYS=30

# website backend environment
N8N_VIDEO_GENERATE_URL=http://127.0.0.1:5678/webhook/video-generate-v2
N8N_VIDEO_STATUS_URL=http://127.0.0.1:5678/webhook/video-status-v2
N8N_VIDEO_JWT_AUDIENCE=n8n-video-workflow
N8N_VIDEO_JWT_ISSUER=video-generator-backend
